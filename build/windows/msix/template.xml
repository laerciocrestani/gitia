<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="openbench"
        Arguments=""
        InstallLocation="C:\Program Files\openbench\openbench">
    </Installer>
    <PackageInformation
        PackageName="openbench"
        PackageDisplayName="openbench"
        PublisherName="CN=openbench"
        PublisherDisplayName="openbench"
        Version="0.1.0.0"
        PackageDescription="Desktop app for AI commits, PRs and Docker workflows">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.laerciocrestani.openbench"
                Description="Desktop app for AI commits, PRs and Docker workflows"
                DisplayName="openbench"
                ExecutableName="openbench"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>openbench</DisplayName>
            <PublisherDisplayName>openbench</PublisherDisplayName>
            <Description>Desktop app for AI commits, PRs and Docker workflows</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="openbench.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
